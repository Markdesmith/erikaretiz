rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
    }
    match /siteConfig/{doc} {
      allow write: if request.auth != null;
    }
    match /sections/{doc} {
      allow write: if request.auth != null;
    }
    match /portfolio/{doc} {
      allow write: if request.auth != null;
    }
  }
}
